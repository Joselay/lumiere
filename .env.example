# OKX demo trading credentials. Never commit real secrets in .env.
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=
OKX_FLAG=1

# Symbols
# Optional fallback symbol.
OKX_INST_ID=BTC-USDT
# Comma-separated symbols the bot trades.
OKX_INST_IDS=BTC-USDT,ETH-USDT
OKX_TD_MODE=cash
# market by default; execution policy may be market, marketable_limit, or post_only_maker.
OKX_ORDER_TYPE=market
OKX_EXECUTION_POLICY=market
OKX_LIMIT_CANCEL_REPLACE_TIMEOUT_SECONDS=30
OKX_ORDER_TAG=lumieredemo

# Telegram
TELEGRAM_BOT_TOKEN=
# Optional comma-separated allowlist. Empty means all chats can control the bot.
TELEGRAM_ALLOWED_CHAT_IDS=

# Logging
# DEBUG, INFO, WARNING, ERROR, or CRITICAL. Console output is colorful when attached to a TTY.
LOG_LEVEL=INFO

# Engine
ENGINE_POLL_INTERVAL_SECONDS=30
ENGINE_CANDLE_BAR=1m
ENGINE_CANDLE_LIMIT=80
# Persisted live/demo position provenance and protective exit controls.
LIVE_POSITION_STATE_PATH=data/live_positions.json
# block requires an explicit operator choice for starting inventory; alternatives: adopt, flatten, ignore.
LIVE_UNEXPECTED_POSITION_POLICY=block
LIVE_STOP_LOSS_BPS=0
LIVE_TAKE_PROFIT_BPS=0
LIVE_TRAILING_STOP_BPS=0
LIVE_MAX_BARS_IN_TRADE=0
LIVE_MAX_POSITION_AGE_SECONDS=0
LIVE_MAX_UNREALIZED_LOSS_USDT=0

# Strategy
# moving_average_crossover, rsi_mean_reversion, or volatility_breakout
STRATEGY_NAME=moving_average_crossover
STRATEGY_FAST_WINDOW=5
STRATEGY_SLOW_WINDOW=20
STRATEGY_RSI_PERIOD=14
STRATEGY_OVERSOLD_RSI=30
STRATEGY_OVERBOUGHT_RSI=70
STRATEGY_BREAKOUT_LOOKBACK=20
STRATEGY_BREAKOUT_ATR_PERIOD=14
STRATEGY_BREAKOUT_ATR_MULTIPLIER=0.5
STRATEGY_BREAKOUT_MIN_ATR_PCT=0.001
STRATEGY_TRADE_SIZE_BTC=0.001
STRATEGY_TRADE_SIZE_ETH=0.01
STRATEGY_DUST_THRESHOLD_BTC=0.00001
STRATEGY_DUST_THRESHOLD_ETH=0.0001

# Risk controls
RISK_MAX_POSITION_BTC=0.005
RISK_MAX_POSITION_ETH=0.05
RISK_MIN_ORDER_BTC=0.00001
RISK_MIN_ORDER_ETH=0.0001
RISK_MAX_DAILY_LOSS_USDT=25
RISK_COOLDOWN_SECONDS=300
RISK_MAX_CONSECUTIVE_FAILURES=3
# Set to positive values to enable additional trading stops.
RISK_MAX_DRAWDOWN_USDT=0
RISK_MAX_DAILY_TRADES=0
RISK_MAX_SPREAD_BPS=0
RISK_MIN_EXPECTED_EDGE_BUFFER_BPS=0
RISK_MAX_RISK_PER_TRADE_PCT=0
RISK_MAX_PORTFOLIO_EXPOSURE_PCT=1
RISK_DRAWDOWN_DERISK_THRESHOLD_USDT=0
RISK_DRAWDOWN_DERISK_MULTIPLIER=0.5
# Set both to positive values before enabling OKX_EXECUTION_POLICY=post_only_maker.
RISK_MAX_MAKER_NON_FILL_RATE=0
RISK_MAX_MAKER_ADVERSE_SELECTION_BPS=0
# When true, account snapshots must include a passing rolling paper/live gate before orders pass risk.
RISK_REQUIRE_PERFORMANCE_GATE=false
# Demo-only research escape hatch: waives optimizer/performance-gate startup checks while
# keeping other risk controls. Requires RISK_MAX_DAILY_TRADES and does not count as readiness.
DEMO_RESEARCH_MODE=false
PAPER_LEDGER_PATH=data/paper_trading.jsonl
ATTRIBUTION_LEDGER_PATH=data/attribution.jsonl
PERFORMANCE_GATE_MIN_TRADES=20
PERFORMANCE_GATE_MIN_NET_PNL_USDT=0
PERFORMANCE_GATE_MAX_DRAWDOWN_USDT=0
PERFORMANCE_GATE_MIN_PROFIT_FACTOR=1
PERFORMANCE_GATE_MAX_EVIDENCE_AGE_HOURS=168
